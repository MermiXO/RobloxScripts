-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Variables
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Remotes
local clickRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Click")
local equipRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Inventory")
local rewardRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Rewards")
local itemRemote   = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Item")

-- States
local clickingActive = false
local equipActive    = false
local rewardsActive  = false
local glovesActive   = false

-- Create GUI Container
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "UltimateFarmGui"
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 580, 0, 60)
mainFrame.Position = UDim2.new(0.5, -290, 0.05, 0)
mainFrame.BackgroundTransparency = 1
mainFrame.Parent = screenGui

-- Helper function to create buttons
local function createButton(name, text, pos)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 130, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) -- Dark Grey
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.Parent = mainFrame
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    return btn
end

-- Create Buttons
local clickBtn  = createButton("ClickBtn",  "AutoClick: OFF",   UDim2.new(0, 0, 0, 0))
local equipBtn  = createButton("EquipBtn",  "Auto Best: OFF",   UDim2.new(0, 145, 0, 0))
local rewardBtn = createButton("RewardBtn", "Auto Reward: OFF", UDim2.new(0, 290, 0, 0))
local gloveBtn  = createButton("GloveBtn",  "Auto Glove: OFF",  UDim2.new(0, 435, 0, 0))

-- Toggle Colors & Logic
local function updateStyle(btn, state)
    btn.BackgroundColor3 = state and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
end

clickBtn.MouseButton1Click:Connect(function()
    clickingActive = not clickingActive
    clickBtn.Text = clickingActive and "AutoClick: ON" or "AutoClick: OFF"
    updateStyle(clickBtn, clickingActive)
end)

equipBtn.MouseButton1Click:Connect(function()
    equipActive = not equipActive
    equipBtn.Text = equipActive and "Auto Best: ON" or "Auto Best: OFF"
    updateStyle(equipBtn, equipActive)
end)

rewardBtn.MouseButton1Click:Connect(function()
    rewardsActive = not rewardsActive
    rewardBtn.Text = rewardsActive and "Auto Reward: ON" or "Auto Reward: OFF"
    updateStyle(rewardBtn, rewardsActive)
end)

gloveBtn.MouseButton1Click:Connect(function()
    glovesActive = not glovesActive
    gloveBtn.Text = glovesActive and "Auto Glove: ON" or "Auto Glove: OFF"
    updateStyle(gloveBtn, glovesActive)
end)

-- Loop: Auto Clicking (Super Fast)
task.spawn(function()
    while true do
        if clickingActive then
            clickRemote:FireServer("Click")
        end
        task.wait(0.01)
    end
end)

-- Loop: Auto Equip Best
task.spawn(function()
    while true do
        if equipActive then
            equipRemote:FireServer("Best")
        end
        task.wait(5)
    end
end)

-- Loop: Auto Rewards (Daily + Gifts 1-15)
task.spawn(function()
    while true do
        if rewardsActive then
            -- Claim Daily
            rewardRemote:FireServer("Daily")
            -- Claim Gifts 1 through 15
            for i = 1, 15 do
                rewardRemote:FireServer("Gifts", i)
            end
        end
        task.wait(30) -- Check every 30 seconds
    end
end)

-- Loop: Auto Equip Gloves (1 to 25)
task.spawn(function()
    while true do
        if glovesActive then
            for i = 1, 25 do
                if not glovesActive then break end
                itemRemote:FireServer("Equip", i)
                task.wait(0.3) -- Fast cycle through owned gloves
            end
        end
        task.wait(5)
    end
end)
